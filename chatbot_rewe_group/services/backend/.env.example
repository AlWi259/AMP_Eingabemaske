# Azure Storage – Connection String des Storage Accounts styggdrasil
AzureWebJobsStorage=DefaultEndpointsProtocol=https;AccountName=styggdrasil;AccountKey=...;EndpointSuffix=core.windows.net

# Key Vault
KEY_VAULT_URL=https://kv-yggdrasil-test01.vault.azure.net/

# Optionale Overrides (werden sonst aus Key Vault geladen)
# OPENAI_API_URL=https://aif-yggdrasil.cognitiveservices.azure.com/
# OPENAI_API_KEY=...

# Langfuse (optional, für LLM Observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Sonstiges
INTERVIEW_ID=copilot
ENVIRONMENT=prod
