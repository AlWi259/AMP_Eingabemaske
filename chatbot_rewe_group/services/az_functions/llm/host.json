{
  "version": "2.0",
  "logging": {
    "logLevel": {
      "default": "Warning",
      "Function": "Warning",
      "Host.Results": "Warning",
      "Host.Aggregator": "Warning",
      "Azure.Core": "Warning",
      "Azure.Data.Tables": "Warning"
    },
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true
      }
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  }
}